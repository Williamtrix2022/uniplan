# ============================================
# UNIPLAN BACKEND - VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores
# ============================================

# Entorno
NODE_ENV=production

# Puerto (Vercel lo ignora; util solo en local)
PORT=3000

# ========== BASE DE DATOS MYSQL ==========
DB_HOST=tu-host-mysql.ejemplo.com
DB_USER=uniplan_user
DB_PASSWORD=tu_password_segura
DB_NAME=uniplan
DB_PORT=3306

# ========== JWT ==========
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio_minimo_32_chars
JWT_EXPIRE=7d

# ========== BCRYPT ==========
BCRYPT_ROUNDS=10

# ========== RECUPERACION DE CONTRASENA ==========
RESET_PASSWORD_URL=uniplan://reset-password
RESET_PASSWORD_WEB_URL=
RESET_TOKEN_EXPIRE_MINUTES=30

# ========== EMAIL - elige UNA opcion ==========

# Opcion A: Resend (recomendado - https://resend.com, plan gratis disponible)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@tudominio.com

# Opcion B: SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=tu_app_password_de_gmail
# SMTP_FROM=tu@gmail.com
