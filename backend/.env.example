# ==================================
# UNIPLAN BACKEND - VARIABLES DE ENTORNO
# ==================================
# Copia este archivo como .env y configura tus valores

# ========== SERVIDOR ==========
PORT=3000
NODE_ENV=development

# ========== BASE DE DATOS ==========
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=uniplan_database
DB_PORT=3306

# ========== JWT ==========
# IMPORTANTE: Cambia esto en producción por una clave segura
JWT_SECRET=cambia_esta_clave_por_algo_super_seguro_en_produccion
JWT_EXPIRE=7d

# ========== CONFIGURACIÓN ==========
BCRYPT_ROUNDS=10

# ========== PASSWORD RESET / SMTP ==========
RESET_PASSWORD_URL=uniplan://reset-password
# Opcional (recomendado): URL web para que el correo siempre muestre enlace clickeable
RESET_PASSWORD_WEB_URL=https://tu-dominio.com/reset-password
RESET_TOKEN_EXPIRE_MINUTES=30

# Opción A: Resend API
RESEND_API_KEY=
RESEND_FROM=Uniplan <no-reply@uniplan.app>

# Opción B: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@ejemplo.com
SMTP_PASS=tu_password_o_app_password
SMTP_FROM=Uniplan <no-reply@uniplan.app>
