# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT
JWT_SECRET=
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# Gmail SMTP (proveedor principal)
# 1. Activá verificación en 2 pasos en tu cuenta Google
# 2. Ir a: myaccount.google.com/apppasswords
# 3. Generá una App Password para 'Correo'
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=tu_correo@gmail.com

# Password Reset
RESET_PASSWORD_URL=uniplan://reset-password?
RESET_PASSWORD_WEB_URL=
RESET_TOKEN_EXPIRE_MINUTES=30

# MailerSend (alternativo - comentado)
# MAILERSEND_API_KEY=
# MAILERSEND_FROM=
# MAILERSEND_FROM_NAME=
